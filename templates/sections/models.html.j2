    <!-- ══ SECTION: MODELS ════════════════════════════════════════════════ -->
    <section id="models" x-data="modelsApp()" x-init="init()">
      <div class="flex items-center justify-between mb-6">
        <div>
          <p class="font-mono text-xs text-[#990033] uppercase tracking-[0.2em] mb-1 select-none">// 02</p>
          <h2 class="text-2xl font-bold text-gray-900" x-text="t('nav.models')"></h2>
        </div>
        <span class="badge bg-[#F5EEE6] text-[#6B0024]"><span x-text="allModels.length"></span> <span x-text="t('models.total')"></span></span>
      </div>
      <div x-show="loading" class="card p-10 text-center">
        <p class="font-mono text-sm animate-pulse text-[#990033]">&gt; indexing models...</p>
      </div>
      <div x-show="!loading">

      <!-- Search + Filter -->
      <div class="flex flex-col sm:flex-row gap-3 mb-4">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            type="text"
            x-model="search"
            :placeholder="t('models.search_ph')"
            class="w-full pl-10 pr-4 py-2 border border-[#DDCDB7] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#990033] bg-white"
          />
        </div>
        <div class="flex gap-2">
          <template x-for="f in filters" :key="f.value">
            <button
              @click="filter = f.value; page = 1"
              :class="filter === f.value ? 'bg-[#990033] text-white border-[#990033]' : 'bg-white text-gray-600 border-[#DDCDB7] hover:border-[#990033]'"
              class="px-3 py-2 rounded-lg border text-sm transition-colors"
              x-text="t(f.i18n_key)"
            ></button>
          </template>
        </div>
      </div>

      <!-- Table -->
      <div class="card overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-[#1a0008] border-b border-[#3D0015]">
                <th class="text-left px-4 py-3 font-mono text-xs font-semibold text-[#DDCDB7] uppercase tracking-widest" x-text="t('models.col.name')"></th>
                <th class="text-left px-4 py-3 font-mono text-xs font-semibold text-[#DDCDB7] uppercase tracking-widest hidden sm:table-cell" x-text="t('models.col.provider')"></th>
                <th class="text-left px-4 py-3 font-mono text-xs font-semibold text-[#DDCDB7] uppercase tracking-widest hidden md:table-cell" x-text="t('models.col.type')"></th>
                <th class="text-left px-4 py-3 font-mono text-xs font-semibold text-[#DDCDB7] uppercase tracking-widest hidden lg:table-cell" x-text="t('models.col.released')"></th>
                <th class="text-left px-4 py-3 font-mono text-xs font-semibold text-[#DDCDB7] uppercase tracking-widest" x-text="t('models.col.summary')"></th>
              </tr>
            </thead>
            <tbody>
              <template x-for="model in paginatedModels" :key="model.name + model.provider">
                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-3">
                    <a :href="model.url || '#'" target="_blank" rel="noopener"
                       class="font-medium text-gray-900 hover:text-[#990033] transition-colors"
                       x-text="model.name"></a>
                    <div class="flex gap-1 mt-1 flex-wrap">
                      <template x-for="m in (model.modality || [])" :key="m">
                        <span class="badge bg-[#FDF6F0] text-[#7A0029]" x-text="m"></span>
                      </template>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-gray-600 hidden sm:table-cell" x-text="model.provider"></td>
                  <td class="px-4 py-3 hidden md:table-cell">
                    <span :class="model.type === 'open' ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700'"
                          class="badge" x-text="model.type === 'open' ? t('models.filter.open') : t('models.filter.closed')"></span>
                  </td>
                  <td class="px-4 py-3 text-gray-400 text-xs hidden lg:table-cell" x-text="model.released_at || '—'"></td>
                  <td class="px-4 py-3 text-gray-600 text-xs max-w-xs" x-text="model.summary"></td>
                </tr>
              </template>
              <tr x-show="filteredModels.length === 0">
                <td colspan="5" class="px-4 py-8 text-center text-gray-400" x-text="t('models.no_results')"></td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-between px-4 py-3 border-t border-gray-100" x-show="totalPages > 1">
          <span class="text-sm text-gray-500">
            <span x-text="t('models.showing')"></span>
            <span x-text="(page-1)*perPage + 1"></span>–<span x-text="Math.min(page*perPage, filteredModels.length)"></span>
            <span x-text="t('models.of')"></span>
            <span x-text="filteredModels.length"></span>
          </span>
          <div class="flex gap-1">
            <button @click="page--" :disabled="page === 1"
                    class="px-3 py-1 rounded border text-sm disabled:opacity-40 hover:bg-gray-50" x-text="t('pagination.prev')"></button>
            <template x-for="p in pageNumbers" :key="p">
              <button @click="page = p"
                      :class="p === page ? 'bg-[#990033] text-white border-[#990033]' : 'hover:bg-[#F5EEE6]'"
                      class="px-3 py-1 rounded border text-sm min-w-[2rem]"
                      x-text="p"></button>
            </template>
            <button @click="page++" :disabled="page === totalPages"
                    class="px-3 py-1 rounded border text-sm disabled:opacity-40 hover:bg-gray-50" x-text="t('pagination.next')"></button>
          </div>
        </div>
      </div>
      </div>
    </section>
