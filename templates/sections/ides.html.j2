    <!-- ══ SECTION: AI IDEs ═══════════════════════════════════════════════ -->
    <section id="ides" x-data="idesApp()" x-init="init()">
      <div class="flex items-center justify-between mb-6">
        <div>
          <p class="font-mono text-xs text-[#990033] uppercase tracking-[0.2em] mb-1 select-none">// 05</p>
          <h2 class="text-2xl font-bold text-gray-900" x-text="t('nav.ides')"></h2>
        </div>
        <span class="badge bg-[#F5EEE6] text-[#6B0024]"><span x-text="items.length"></span> IDEs</span>
      </div>
      <div x-show="loading" class="card p-10 text-center text-gray-400">
        <p class="font-mono text-sm animate-pulse text-[#990033]">&gt; loading IDEs...</p>
      </div>
      <div x-show="!loading" class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <template x-for="ide in items" :key="ide.name">
          <div class="card p-5 flex flex-col gap-3">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="font-bold text-lg text-gray-900" x-text="ide.name"></h3>
                <p class="text-sm text-gray-500" x-text="ide.company"></p>
              </div>
              <div class="flex items-center gap-1.5">
                <span x-show="ide.open_source" class="badge bg-green-100 text-green-700">Open Source</span>
              </div>
            </div>
            <p class="text-gray-500 text-sm italic">"<span x-text="$store.lang === 'zh' ? (ide.tagline_zh || ide.tagline) : ide.tagline"></span>"</p>
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5"
                 x-text="t('ides.ai_features')"></p>
              <p class="text-sm text-gray-700 leading-relaxed" x-text="$store.lang === 'zh' ? (ide.ai_features_zh || ide.ai_features) : ide.ai_features"></p>
            </div>
            <div class="flex items-center justify-between mt-auto pt-2 border-t border-gray-100">
              <span class="text-sm font-medium text-emerald-600" x-text="ide.pricing"></span>
              <a :href="ide.url" target="_blank" rel="noopener"
                 class="text-xs text-[#990033] hover:underline font-medium"
                 x-text="t('ides.visit')"></a>
            </div>
            <p x-show="ide.base" class="text-xs text-gray-400">
              <span x-text="t('ides.base')"></span>: <span x-text="ide.base"></span>
            </p>
          </div>
        </template>
      </div>
    </section>
