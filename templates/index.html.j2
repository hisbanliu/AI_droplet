<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Droplet — Daily AI Intelligence</title>
  <meta name="description" content="Your daily snapshot of AI models, tools, news, MCP servers, and agent skills." />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50:  '#FDF6F0',
              100: '#F5EEE6',
              200: '#DDCDB7',
              300: '#C4B49E',
              500: '#990033',
              600: '#7A0029',
              700: '#5C001F',
            }
          },
          fontFamily: {
            heading: ['Fira Code', 'ui-monospace', 'monospace'],
            body:    ['Inter', 'system-ui', 'sans-serif'],
          }
        }
      }
    }
  </script>

  <!-- Alpine.js -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

  <style>
    [x-cloak] { display: none !important; }
    html { scroll-behavior: smooth; }
    .tab-active { @apply border-b-2 border-[#990033] text-[#990033] font-semibold; }
    .card {
      @apply bg-white rounded-lg border border-[#DDCDB7] shadow-sm
             transition-all duration-200 cursor-pointer;
    }
    .card:hover {
      box-shadow: 0 0 0 1px rgba(153,0,51,0.20), 0 4px 16px rgba(153,0,51,0.08);
      border-color: #C4B49E;
    }
    .badge { @apply inline-flex items-center px-2 py-0.5 rounded text-xs font-mono font-medium tracking-wide; }
    .tech-label {
      @apply font-mono text-xs text-[#990033] uppercase tracking-[0.2em] mb-1 select-none;
    }
    .hero-grid {
      background-image:
        linear-gradient(rgba(221,205,183,0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(221,205,183,0.07) 1px, transparent 1px);
      background-size: 48px 48px;
    }
    @media (prefers-reduced-motion: reduce) {
      * { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
    }
  </style>
</head>

<body class="bg-[#F5EEE6] text-gray-900 min-h-screen font-body" x-data="app()" x-cloak>

  <!-- ══ NAVBAR ══════════════════════════════════════════════════════════════ -->
  <nav class="sticky top-0 z-50 bg-[#0D0006]/95 backdrop-blur border-b border-[#3D0015]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">

      <!-- Logo -->
      <a href="#" class="flex items-center gap-2 font-heading font-bold text-[#DDCDB7] text-base tracking-tight">
        <span class="text-[#990033] font-heading font-bold">&lt;/&gt;</span>
        AI Droplet
      </a>

      <!-- Nav tabs (hidden on mobile, shown md+) -->
      <div class="hidden md:flex items-center gap-1 text-sm">
        <template x-for="tab in tabs" :key="tab.id">
          <button
            @click="activeTab = tab.id; $nextTick(() => document.getElementById(tab.id)?.scrollIntoView({behavior:'smooth'}))"
            :class="activeTab === tab.id ? 'text-[#DDCDB7] border-b-2 border-[#990033] font-semibold' : 'text-[#9C8070] hover:text-[#DDCDB7]'"
            class="px-3 py-1.5 font-mono text-xs uppercase tracking-widest transition-colors cursor-pointer"
            x-text="t(tab.i18n_key)"
          ></button>
        </template>
      </div>

      <!-- Right: lang toggle + generated date -->
      <div class="flex items-center gap-3">
        <span class="hidden sm:block text-xs text-[#6B4A3A] font-mono">{{ generated_at }}</span>
        <div class="flex items-center border border-[#3D0015] overflow-hidden text-xs font-mono">
          <button
            @click="setLang('en')"
            :class="lang === 'en' ? 'bg-[#990033] text-white' : 'text-[#9C8070] hover:bg-[#1a0008]'"
            class="px-3 py-1.5 transition-colors cursor-pointer"
          >EN</button>
          <button
            @click="setLang('zh')"
            :class="lang === 'zh' ? 'bg-[#990033] text-white' : 'text-[#9C8070] hover:bg-[#1a0008]'"
            class="px-3 py-1.5 transition-colors cursor-pointer"
          >中</button>
        </div>
      </div>
    </div>
  </nav>

  <!-- ══ HERO ════════════════════════════════════════════════════════════════ -->
  <header class="relative bg-[#0D0006] text-white py-16 px-4 overflow-hidden">
    <!-- Grid pattern -->
    <div class="hero-grid absolute inset-0 pointer-events-none"></div>
    <!-- Radial glow -->
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 80% 60% at 50% 0%, rgba(153,0,51,0.30), transparent)"></div>
    <div class="relative max-w-7xl mx-auto text-center">
      <p class="font-mono text-xs text-[#990033] uppercase tracking-[0.2em] mb-4 select-none">// Daily Intelligence Feed</p>
      <h1 class="text-3xl sm:text-4xl font-heading font-bold mb-3 tracking-tight text-white" x-text="t('hero.title')"></h1>
      <p class="text-[#6B4A3A] text-base max-w-2xl mx-auto leading-relaxed" x-text="t('hero.subtitle')"></p>
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-px max-w-2xl mx-auto border border-[#3D0015]">
        <div class="bg-[#0D0006] px-4 py-4 text-center border-r border-b sm:border-b-0 border-[#3D0015]">
          <div class="font-heading text-2xl font-bold text-white" x-text="newsCount || '—'"></div>
          <div class="text-xs text-[#6B4A3A] mt-1 font-mono uppercase tracking-widest" x-text="t('hero.stat.news')"></div>
        </div>
        <div class="bg-[#0D0006] px-4 py-4 text-center border-b sm:border-b-0 sm:border-r border-[#3D0015]">
          <div class="font-heading text-2xl font-bold text-white" x-text="modelsCount || '—'"></div>
          <div class="text-xs text-[#6B4A3A] mt-1 font-mono uppercase tracking-widest" x-text="t('hero.stat.models')"></div>
        </div>
        <div class="bg-[#0D0006] px-4 py-4 text-center border-r border-[#3D0015]">
          <div class="font-heading text-2xl font-bold text-[#DDCDB7]" x-text="mcpCount || '—'"></div>
          <div class="text-xs text-[#6B4A3A] mt-1 font-mono uppercase tracking-widest">MCP Servers</div>
        </div>
        <div class="bg-[#0D0006] px-4 py-4 text-center">
          <div class="font-heading text-2xl font-bold text-[#DDCDB7]" x-text="skillsCount || '—'"></div>
          <div class="text-xs text-[#6B4A3A] mt-1 font-mono uppercase tracking-widest">Agent Skills</div>
        </div>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-10 space-y-16">

    {%- include 'sections/news.html.j2' %}

    {%- include 'sections/models.html.j2' %}

    {%- include 'sections/mcp.html.j2' %}

    {%- include 'sections/skills.html.j2' %}

    {%- include 'sections/ides.html.j2' %}

    {%- include 'sections/tools.html.j2' %}

  </main>

  <!-- ══ FOOTER ══════════════════════════════════════════════════════════════ -->
  <footer class="border-t border-[#DDCDB7] mt-16 py-8 text-center text-sm text-gray-500">
    <p class="font-mono text-xs text-[#990033] mb-2 select-none">// eof</p>
    <p>AI Droplet · <span x-text="t('footer.generated')"></span> {{ generated_at }}</p>
    <p class="mt-1">
      <a href="https://github.com/hisbanliu/AI_droplet" target="_blank" rel="noopener"
         class="hover:text-[#990033] transition-colors">GitHub</a>
      &nbsp;·&nbsp;
      <span x-text="t('footer.data_sources')"></span>: OpenAI, Anthropic, Google, HuggingFace, GitHub, arXiv
    </p>
  </footer>

  <!-- ══ SCRIPTS ══════════════════════════════════════════════════════════════ -->
  <script>
  // ── i18n ──────────────────────────────────────────────────────────────────
  const TRANSLATIONS = {
    en: {
      'hero.title':           'Your Daily AI Intelligence',
      'hero.subtitle':        'Models, tools, news, MCP servers, and agent skills — all in one place, updated daily.',
      'hero.stat.news':       'top stories today',
      'hero.stat.models':     'models tracked',
      'nav.news':             'Daily News',
      'nav.models':           'Models',
      'nav.mcp':              'MCP',
      'nav.skills':           'Agent Skills',
      'nav.ides':             'AI IDEs',
      'nav.tools':            'AI Tools',
      'news.read_more':       'Read →',
      'news.empty':           'No news loaded yet.',
      'news.empty_hint':      'Run: python scripts/fetch_news.py',
      'models.search_ph':     'Search models...',
      'models.total':         'total',
      'models.col.name':      'Model',
      'models.col.provider':  'Provider',
      'models.col.type':      'Type',
      'models.col.released':  'Released',
      'models.col.summary':   'Summary',
      'models.filter.all':    'All',
      'models.filter.open':   'Open Source',
      'models.filter.closed': 'Closed Source',
      'models.no_results':    'No models match your search.',
      'models.showing':       'Showing',
      'models.of':            'of',
      'mcp.search_ph':        'Search MCP servers...',
      'mcp.all_categories':   'All categories',
      'mcp.empty':            'No MCP servers loaded yet.',
      'mcp.empty_hint':       'Run: python scripts/fetch_mcp.py',
      'mcp.no_results':       'No servers match your search.',
      'skills.docs':          'Docs →',
      'ides.ai_features':     'AI Features',
      'ides.visit':           'Visit →',
      'ides.base':            'Based on',
      'tools.visit':          'Visit →',
      'tools.cat.image-generation': 'Image Generation',
      'tools.cat.video-generation': 'Video Generation',
      'tools.cat.audio':      'Audio & Music',
      'tools.cat.ai-search':  'AI Search',
      'tools.cat.coding':     'Coding',
      'tools.cat.productivity': 'Productivity',
      'tools.cat.ai-agents':  'AI Agents',
      'tools.cat.writing':    'AI Writing',
      'pagination.prev':      'Prev',
      'pagination.next':      'Next',
      'footer.generated':     'Generated',
      'footer.data_sources':  'Data sources',
    },
    zh: {
      'hero.title':           '你的每日 AI 情报站',
      'hero.subtitle':        '模型、工具、新闻、MCP 服务器和 Agent Skills —— 一站掌握，每日更新。',
      'hero.stat.news':       '条今日精选',
      'hero.stat.models':     '个模型收录',
      'nav.news':             '每日新闻',
      'nav.models':           '大模型',
      'nav.mcp':              'MCP',
      'nav.skills':           'Agent Skills',
      'nav.ides':             'AI IDE',
      'nav.tools':            'AI 工具',
      'news.read_more':       '阅读全文 →',
      'news.empty':           '暂无新闻数据。',
      'news.empty_hint':      '运行: python scripts/fetch_news.py',
      'models.search_ph':     '搜索模型...',
      'models.total':         '个模型',
      'models.col.name':      '模型',
      'models.col.provider':  '发布方',
      'models.col.type':      '类型',
      'models.col.released':  '发布时间',
      'models.col.summary':   '简介',
      'models.filter.all':    '全部',
      'models.filter.open':   '开源',
      'models.filter.closed': '闭源',
      'models.no_results':    '没有匹配的模型。',
      'models.showing':       '显示',
      'models.of':            '/',
      'mcp.search_ph':        '搜索 MCP 服务器...',
      'mcp.all_categories':   '全部分类',
      'mcp.empty':            '暂无 MCP 数据。',
      'mcp.empty_hint':       '运行: python scripts/fetch_mcp.py',
      'mcp.no_results':       '没有匹配的服务器。',
      'skills.docs':          '文档 →',
      'ides.ai_features':     'AI 功能',
      'ides.visit':           '访问 →',
      'ides.base':            '基于',
      'tools.visit':          '访问 →',
      'tools.cat.image-generation': '图像生成',
      'tools.cat.video-generation': '视频生成',
      'tools.cat.audio':      '音频 & 音乐',
      'tools.cat.ai-search':  'AI 搜索',
      'tools.cat.coding':     '代码助手',
      'tools.cat.productivity': '生产力',
      'tools.cat.ai-agents':  'AI 智能体',
      'tools.cat.writing':    'AI 写作',
      'pagination.prev':      '上一页',
      'pagination.next':      '下一页',
      'footer.generated':     '生成于',
      'footer.data_sources':  '数据来源',
    }
  }

  // ── Alpine Store: shared language state ────────────────────────────────
  document.addEventListener('alpine:init', () => {
    Alpine.store('lang', localStorage.getItem('ai-droplet-lang') || 'en')
  })

  function t(key) {
    const lang = (typeof Alpine !== 'undefined' && Alpine.store) ? Alpine.store('lang') : 'en'
    return (TRANSLATIONS[lang] || TRANSLATIONS.en)[key] || key
  }

  // ── Base URL for data files (works both on GitHub Pages and locally) ──────
  const BASE = (() => {
    const s = document.currentScript || {}
    // Derive from current page URL: strip index.html if present
    const url = location.href.replace(/\/index\.html.*$/, '').replace(/\/$/, '')
    return url + '/data'
  })()

  async function fetchData(filename) {
    try {
      const res = await fetch(`${BASE}/${filename}`)
      if (!res.ok) return []
      return await res.json()
    } catch { return [] }
  }

  // ── Main App ──────────────────────────────────────────────────────────────
  function app() {
    return {
      lang: localStorage.getItem('ai-droplet-lang') || 'en',
      activeTab: 'news',
      newsCount: 0,
      modelsCount: 0,
      mcpCount: 0,
      skillsCount: 0,
      async init() {
        const [news, models, mcp, skills] = await Promise.all([
          fetchData('news.json'),
          fetchData('models.json'),
          fetchData('mcp.json'),
          fetchData('skills.json'),
        ])
        this.newsCount = news.length
        this.modelsCount = models.length
        this.mcpCount = mcp.length
        this.skillsCount = skills.length
      },
      tabs: [
        { id: 'news',   i18n_key: 'nav.news' },
        { id: 'models', i18n_key: 'nav.models' },
        { id: 'mcp',    i18n_key: 'nav.mcp' },
        { id: 'skills', i18n_key: 'nav.skills' },
        { id: 'ides',   i18n_key: 'nav.ides' },
        { id: 'tools',  i18n_key: 'nav.tools' },
      ],
      setLang(l) {
        this.lang = l
        Alpine.store('lang', l)
        localStorage.setItem('ai-droplet-lang', l)
      },
      t(key) {
        return (TRANSLATIONS[this.lang] || TRANSLATIONS.en)[key] || key
      }
    }
  }

  // ── News Section ──────────────────────────────────────────────────────────
  function newsApp() {
    return {
      loading: true,
      items: [],
      async init() {
        this.items = await fetchData('news.json')
        this.loading = false
      },
      t(key) { return (TRANSLATIONS[Alpine.store('lang')] || TRANSLATIONS.en)[key] || key }
    }
  }

  // ── Models Section ────────────────────────────────────────────────────────
  function modelsApp() {
    return {
      loading: true,
      allModels: [],
      search: '',
      filter: 'all',
      page: 1,
      perPage: 20,
      filters: [
        { value: 'all',    i18n_key: 'models.filter.all' },
        { value: 'closed', i18n_key: 'models.filter.closed' },
        { value: 'open',   i18n_key: 'models.filter.open' },
      ],
      async init() {
        this.allModels = await fetchData('models.json')
        this.loading = false
      },
      get filteredModels() {
        const q = this.search.toLowerCase()
        return this.allModels.filter(m => {
          const matchSearch = !q ||
            (m.name || '').toLowerCase().includes(q) ||
            (m.provider || '').toLowerCase().includes(q) ||
            (m.summary || '').toLowerCase().includes(q)
          const matchFilter = this.filter === 'all' || m.type === this.filter
          return matchSearch && matchFilter
        })
      },
      get totalPages() {
        return Math.max(1, Math.ceil(this.filteredModels.length / this.perPage))
      },
      get paginatedModels() {
        const start = (this.page - 1) * this.perPage
        return this.filteredModels.slice(start, start + this.perPage)
      },
      get pageNumbers() {
        const total = this.totalPages
        const current = this.page
        if (total <= 7) return Array.from({length: total}, (_, i) => i + 1)
        if (current <= 4) return [1, 2, 3, 4, 5, '...', total]
        if (current >= total - 3) return [1, '...', total-4, total-3, total-2, total-1, total]
        return [1, '...', current-1, current, current+1, '...', total]
      },
      t(key) { return (TRANSLATIONS[Alpine.store('lang')] || TRANSLATIONS.en)[key] || key }
    }
  }

  // ── MCP Section ───────────────────────────────────────────────────────────
  function mcpApp() {
    return {
      loading: true,
      allMcp: [],
      search: '',
      category: '',
      page: 1,
      perPage: 30,
      async init() {
        this.allMcp = await fetchData('mcp.json')
        this.loading = false
      },
      get categories() {
        return [...new Set(this.allMcp.map(m => m.category).filter(Boolean))].sort()
      },
      get filteredMcp() {
        const q = this.search.toLowerCase()
        return this.allMcp.filter(m => {
          const matchSearch = !q ||
            (m.name || '').toLowerCase().includes(q) ||
            (m.description || '').toLowerCase().includes(q)
          const matchCat = !this.category || m.category === this.category
          return matchSearch && matchCat
        })
      },
      get totalPages() {
        return Math.max(1, Math.ceil(this.filteredMcp.length / this.perPage))
      },
      get paginatedMcp() {
        const start = (this.page - 1) * this.perPage
        return this.filteredMcp.slice(start, start + this.perPage)
      },
      t(key) { return (TRANSLATIONS[Alpine.store('lang')] || TRANSLATIONS.en)[key] || key }
    }
  }

  // ── Skills Section ────────────────────────────────────────────────────────
  function skillsApp() {
    return {
      loading: true,
      items: [],
      async init() {
        this.items = await fetchData('skills.json')
        this.loading = false
      },
      t(key) { return (TRANSLATIONS[Alpine.store('lang')] || TRANSLATIONS.en)[key] || key }
    }
  }

  // ── IDEs Section ──────────────────────────────────────────────────────────
  function idesApp() {
    return {
      loading: true,
      items: [],
      async init() {
        this.items = await fetchData('ides.json')
        this.loading = false
      },
      t(key) { return (TRANSLATIONS[Alpine.store('lang')] || TRANSLATIONS.en)[key] || key }
    }
  }

  // ── Tools Section ─────────────────────────────────────────────────────────
  function toolsApp() {
    return {
      loading: true,
      allTools: [],
      toolTab: 'image-generation',
      async init() {
        this.allTools = await fetchData('tools.json')
        if (this.allTools.length > 0) {
          this.toolTab = this.allTools[0].category
        }
        this.loading = false
      },
      get categories() {
        return [...new Set(this.allTools.map(t => t.category).filter(Boolean))]
      },
      get toolsByCategory() {
        const map = {}
        this.allTools.forEach(t => {
          if (!map[t.category]) map[t.category] = []
          map[t.category].push(t)
        })
        return map
      },
      t(key) { return (TRANSLATIONS[Alpine.store('lang')] || TRANSLATIONS.en)[key] || key }
    }
  }
  </script>
</body>
</html>
