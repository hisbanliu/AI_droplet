    <!-- ══ SECTION: NEWS ═══════════════════════════════════════════════════ -->
    <section id="news" x-data="newsApp()" x-init="init()">
      <div class="flex items-center justify-between mb-6">
        <div>
          <p class="font-mono text-xs text-[#990033] uppercase tracking-[0.2em] mb-1 select-none">// 01</p>
          <h2 class="text-2xl font-bold text-gray-900" x-text="t('nav.news')"></h2>
        </div>
        <span class="badge bg-[#F5EEE6] text-[#6B0024] border border-[#DDCDB7]">{{ generated_at[:10] }}</span>
      </div>

      <!-- Loading -->
      <div x-show="loading" class="card p-10 text-center text-gray-400">
        <p class="font-mono text-sm animate-pulse text-[#990033]">&gt; loading feed...</p>
      </div>

      <!-- News grid -->
      <div x-show="!loading && items.length > 0" class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <template x-for="item in items" :key="item.id || item.url">
          <article class="card p-5 flex flex-col gap-3 border-l-2 border-l-transparent hover:border-l-[#990033]">
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="badge bg-[#F5EEE6] text-[#990033]" x-text="item.source"></span>
                <template x-for="tag in (item.tags || []).slice(0,2)" :key="tag">
                  <span class="badge bg-gray-100 text-gray-600" x-text="tag"></span>
                </template>
              </div>
              <span class="text-xs text-gray-400 whitespace-nowrap" x-text="(item.published_at || '').slice(0,10)"></span>
            </div>
            <h3 class="font-semibold text-gray-900 leading-snug">
              <a :href="item.url" target="_blank" rel="noopener" class="hover:text-[#990033] transition-colors" x-text="item.title"></a>
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              <span x-show="$store.lang === 'en' || $store.lang === undefined" x-text="item.summary_en || item.title"></span>
              <span x-show="$store.lang === 'zh'" x-text="item.summary_zh || item.summary_en || item.title"></span>
            </p>
            <div class="flex items-center justify-between mt-auto pt-2">
              <div class="flex items-center gap-1">
                <div class="flex">
                  <template x-for="i in 10" :key="i">
                    <div class="w-1.5 h-3 rounded-sm mr-0.5"
                         :class="i <= (item.importance_score || 7) ? 'bg-[#990033]' : 'bg-[#DDCDB7]'"></div>
                  </template>
                </div>
                <span class="text-xs text-gray-400 ml-1" x-text="(item.importance_score || 7).toFixed(1)"></span>
              </div>
              <a :href="item.url" target="_blank" rel="noopener"
                 class="text-xs text-[#990033] hover:text-[#6B0024] font-medium"
                 x-text="t('news.read_more')"></a>
            </div>
          </article>
        </template>
      </div>

      <!-- Empty -->
      <div x-show="!loading && items.length === 0" class="card p-10 text-center text-gray-400">
        <p class="font-mono text-sm text-[#990033] mb-2">&gt; no data</p>
        <p x-text="t('news.empty')"></p>
        <p class="text-sm mt-1 text-gray-300" x-text="t('news.empty_hint')"></p>
      </div>
    </section>
