# Copy this file to .env and fill in your actual keys
# Never commit .env to git

# AI provider for news scoring: gemini | openai  (default: gemini)
# "openai" covers any OpenAI-compatible API: OpenAI, DeepSeek, Kimi, Qwen, etc.
AI_PROVIDER=gemini

# ── Option A: Google Gemini (default, high free quota) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Option B: OpenAI-compatible providers ──
# Uncomment and fill in to switch to any OpenAI-compatible provider.
# Then set AI_PROVIDER=openai above.
#
# AI_API_KEY=your_api_key_here
#
# DeepSeek:  AI_BASE_URL=https://api.deepseek.com/v1   AI_MODEL=deepseek-chat
# Kimi:      AI_BASE_URL=https://api.moonshot.cn/v1    AI_MODEL=moonshot-v1-8k
# Qwen:      AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  AI_MODEL=qwen-turbo
# OpenAI:    AI_BASE_URL=https://api.openai.com/v1     AI_MODEL=gpt-4o-mini
#
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# GitHub token (optional, raises API rate limit 60→5000 req/h)
GITHUB_TOKEN=your_github_personal_access_token_here
